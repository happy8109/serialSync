{
  "serial": {
    "port": "COM3",
    "baudRate": 115200,
    "dataBits": 8,
    "stopBits": 1,
    "parity": "none",
    "rtscts": true,
    "autoReconnect": true,
    "reconnectInterval": 3000,
    "maxReconnectAttempts": 0
  },
  "transfer": {
    "chunkSize": 1024,
    "windowSize": 5,
    "timeout": 5000
  },
  "message": {
    "maxLength": 4096
  },
  "system": {
    "heartbeatInterval": 5000,
    "heartbeatTimeout": 15000
  },
  "logging": {
    "level": "info",
    "console": true,
    "file": true
  },
  "services": {
    "enabled": true,
    "autoRegister": true,
    "localServices": {
      "system_info": {
        "name": "System Info",
        "description": "Get system status",
        "endpoint": "http://localhost:3000/api/status",
        "method": "GET",
        "enabled": true
      },
      "daily_brief": {
        "name": "每日简报",
        "description": "获取每日统计简报",
        "endpoint": "http://192.168.9.149:3000/api/stats/daily/brief",
        "method": "GET",
        "enabled": true
      }
    }
  },
  "server": {
    "port": 3000
  },
  "web": {
    "port": 5173
  }
}