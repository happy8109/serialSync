{
  "serial": {
    "port": "COM4",
    "baudRate": 576000,
    "dataBits": 8,
    "stopBits": 1,
    "parity": "none",
    "rtscts": true,
    "autoReconnect": true,
    "reconnectInterval": 3000,
    "maxReconnectAttempts": 0,
    "heartbeatInterval": 5000,
    "heartbeatTimeout": 15000,
    "path": "COM4"
  },
  "transfer": {
    "chunkSize": 2048,
    "windowSize": 25,
    "timeout": 5000,
    "savePath": "./received",
    "conflictStrategy": "overwrite"
  },
  "message": {
    "maxLength": 4096
  },
  "system": {
    "heartbeatInterval": 5000,
    "heartbeatTimeout": 15000
  },
  "logging": {
    "level": "info",
    "console": true,
    "file": true
  },
  "services": {
    "enabled": true,
    "autoRegister": true,
    "localServices": {
      "system_info": {
        "name": "System Info",
        "description": "Get system status",
        "version": "1.0",
        "endpoint": "http://localhost:3000/api/status",
        "method": "GET",
        "timeout": 10000,
        "enabled": true,
        "headers": {},
        "params": {}
      },
      "daily_brief": {
        "name": "每日简报",
        "description": "获取每日统计简报",
        "version": "1.0",
        "endpoint": "http://localhost:3000/api/stats/daily/brief",
        "method": "GET",
        "timeout": 10000,
        "enabled": true,
        "headers": {},
        "params": {}
      }
    }
  },
  "server": {
    "port": 3000
  },
  "web": {
    "port": 5173
  },
  "syncTasks": []
}