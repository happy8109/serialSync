{
  "serial": {
    "port": "COM3",
    "baudRate": 115200,
    "dataBits": 8,
    "stopBits": 1,
    "parity": "none",
    "rtscts": true,
    "autoReconnect": true,
    "reconnectInterval": 3000,
    "maxReconnectAttempts": 0
  },
  "transfer": {
    "chunkSize": 1024,
    "windowSize": 5,
    "timeout": 5000
  },
  "message": {
    "maxLength": 4096
  },
  "system": {
    "heartbeatInterval": 5000,
    "heartbeatTimeout": 15000
  },
  "logging": {
    "level": "info",
    "console": true,
    "file": true
  }
}